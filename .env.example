# Proveedor de IA. Opciones:
# - openai-compatible (por defecto, usa fetch nativo)
# - gemini (requiere instalar @google/genai)
LLM_PROVIDER=openai-compatible

# Clave de API del proveedor de IA.
# Para OpenAI, Azure, Anthropic o similares, usa la clave correspondiente.
# Para proveedores autoalojados (Ollama, LM Studio), deja esto vacío o usa una clave dummy.
LLM_API_KEY=tu_api_key_aqui

# (Opcional) URL base para proveedores autoalojados o endpoints personalizados.
# Ejemplos:
# LLM_BASE_URL=http://localhost:11434/v1        # Ollama
# LLM_BASE_URL=http://localhost:1234/v1         # LM Studio
# LLM_BASE_URL=https://api.openai.com/v1        # OpenAI

# Puerto del servidor backend (por defecto 3001)
PORT=3001
