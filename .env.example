# Proveedor de IA. Opciones: gemini | openai-compatible
LLM_PROVIDER=gemini

# Clave de API del proveedor de IA.
# Para Gemini, usa tu clave de Google AI Studio / Vertex AI.
# Para OpenAI-compatible, usa la clave del servicio correspondiente.
LLM_API_KEY=tu_api_key_aqui

# (Opcional) URL base para proveedores OpenAI-compatible (Ollama, LM Studio, Azure, etc.)
# LLM_BASE_URL=http://localhost:11434/v1

# Puerto del servidor backend (por defecto 3001)
PORT=3001
